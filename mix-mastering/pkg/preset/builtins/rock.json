{
  "name": "Rock",
  "category": "genre",
  "description": "Rock genre preset with moderate EQ shaping, punchy compression, and tight limiting for powerful mixes.",
  "author": "AudioMaster",
  "tags": [
    "rock",
    "genre",
    "punchy",
    "guitar",
    "drums"
  ],
  "processors": {
    "Parametric EQ": {
      "band.0.freq": 80,
      "band.0.gain": 2.0,
      "band.0.q": 0.7,
      "band.1.freq": 400,
      "band.1.gain": -1.0,
      "band.1.q": 1.0,
      "band.2.freq": 10000,
      "band.2.gain": 2.0,
      "band.2.q": 0.7,
      "band.0.enabled": 1,
      "band.1.enabled": 1,
      "band.2.enabled": 1
    },
    "Compressor": {
      "threshold": -16,
      "ratio": 4,
      "attack": 10,
      "release": 100,
      "knee": 6,
      "makeup": 3
    },
    "Limiter": {
      "ceiling": -0.3
    }
  }
}
