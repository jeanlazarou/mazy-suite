      "band.1.gain": -2.0,
      "band.1.q": 1.0,
      "band.2.freq": 3000,
      "band.2.gain": 2.0,
      "band.2.q": 1.0,
      "band.0.enabled": 1,
      "band.1.enabled": 1,
      "band.2.enabled": 1
